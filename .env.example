# =============================================================================
# FlowRate — environment variables (team dev reference)
# =============================================================================
#
# Setup
#   cp .env.example .env
#   Fill in the "Required" section below, then: pnpm install && pnpm dev
#
# Secrets
#   • Never commit .env (gitignored).
#   • Shared sandbox keys: team vault / Vercel preview env / ask a maintainer.
#   • Each dev can use their own Neon branch + auth URL for isolated data.
#
# Docs: README.md (quick start) · nuxt.config.ts (runtimeConfig mapping)
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED — minimum to run the app locally
# -----------------------------------------------------------------------------

APP_URL=http://localhost:3000

# Signs session cookies. Min 32 chars. Generate: openssl rand -base64 32
# Alias supported: NEON_AUTH_COOKIE_SECRET
NUXT_SESSION_PASSWORD=change-me-use-openssl-rand-base64-32

# Neon → Project → Connection string (dev branch recommended per developer)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Neon → Project → Branch → Auth → Configuration → Auth URL
NUXT_NEON_AUTH_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth

# Stripe test keys — Dashboard → Developers → API keys (Test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# From `pnpm stripe:listen` (or `pnpm dev:all`). Restart dev after changing.
STRIPE_WEBHOOK_SECRET=whsec_...


# -----------------------------------------------------------------------------
# REQUIRED — Neon Auth admin (account deletion, some auth webhooks)
# -----------------------------------------------------------------------------

# Neon console → Project settings
STACK_PROJECT_ID=your-neon-project-id
NEON_API_KEY=your-neon-api-key

# Optional: branch ID for guardian-initiated account deletion (auto-detected if omitted)
# NEON_BRANCH_ID=br-xxx


# -----------------------------------------------------------------------------
# OPTIONAL — Stripe billing extras
# -----------------------------------------------------------------------------

# Fallback Pro price if Products API lookup fails. Prefer Stripe product metadata planKey=pro
# STRIPE_PRICE_PRO=price_...

# Invoice PDF template from Stripe Dashboard (inrtem_…)
# STRIPE_INVOICE_TEMPLATE_ID=inrtem_...

# Stripe products (create in Dashboard → Product catalog):
#   FlowRate Pro       → metadata planKey=pro
#   FlowRate Enterprise → metadata planKey=enterprise
# Add monthly + yearly prices per product. Test cards: https://docs.stripe.com/testing


# -----------------------------------------------------------------------------
# OPTIONAL — Plaid (EU bank linking)
# -----------------------------------------------------------------------------

# Dashboard → Team Settings → Keys. Sandbox: user_good / pass_good in Link
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

# Must match URI at https://dashboard.plaid.com/team/api (HTTPS only)
# PLAID_REDIRECT_URI=https://your-domain.com/dashboard/accounts/plaid-oauth

# Webhook: TRANSACTIONS (SYNC_UPDATES_AVAILABLE), ITEM (NEW_ACCOUNTS_AVAILABLE)
# PLAID_WEBHOOK_URL=https://your-domain.com/api/plaid/webhook


# -----------------------------------------------------------------------------
# OPTIONAL — Twilio (SMS OTP via Neon Auth webhook + legacy phone verify)
# -----------------------------------------------------------------------------

# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+14155551234


# -----------------------------------------------------------------------------
# OPTIONAL — Auth email (Neon send.otp / send.magic_link webhooks)
# -----------------------------------------------------------------------------

# RESEND_API_KEY=re_...
# AUTH_FROM_EMAIL=auth@your-domain.com


# -----------------------------------------------------------------------------
# OPTIONAL — In-app feedback → GitHub issues
# -----------------------------------------------------------------------------

# Fine-grained PAT: Issues + Contents on the feedback repo
# GITHUB_TOKEN=github_pat_...
# GITHUB_FEEDBACK_REPO=FlowrateOfficial/flowrate


# -----------------------------------------------------------------------------
# OPTIONAL — Admin dashboard (/dashboard/admin/usage)
# -----------------------------------------------------------------------------

# Comma-separated emails
# ADMIN_EMAILS=you@example.com,ops@example.com


# -----------------------------------------------------------------------------
# OPTIONAL — Mapbox address autofill (Settings → billing address)
# -----------------------------------------------------------------------------

# Public token (pk.) — https://docs.mapbox.com/mapbox-search-js/guides/autofill/
# MAPBOX_ACCESS_TOKEN=pk.eyJ...


# -----------------------------------------------------------------------------
# OPTIONAL — Rate limiting (production / multi-instance)
# -----------------------------------------------------------------------------

# Without these, limits use in-memory buckets (fine for local dev)
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...


# =============================================================================
# Local dev workflows
# =============================================================================
#
# Stripe webhooks
#   Terminal 1: pnpm dev
#   Terminal 2: pnpm stripe:listen
#   Paste the whsec_… into STRIPE_WEBHOOK_SECRET and restart dev.
#   Without webhooks: checkout still syncs on redirect; bank sync webhooks return 503.
#
# Neon Auth webhooks (OTP / magic link / phone verified)
#   Neon rejects localhost. Use ngrok (or similar) and register:
#     https://YOUR-SUBDOMAIN.ngrok-free.app/api/webhooks/neon-auth
#   Enable: send.otp, send.magic_link, phone_number.verified, user.created
#   Docs: https://neon.com/docs/auth/guides/webhooks
#
# Neon Auth allowed domains (fix INVALID_ORIGIN on preview deploys)
#   Console → Auth → Configuration → Domains:
#     http://localhost:3000
#     https://your-app.vercel.app
#     https://*.your-app.vercel.app
#
# Plaid on localhost
#   Sandbox works without PLAID_REDIRECT_URI on HTTP.
#   OAuth banks need HTTPS + registered redirect URI.
#
# Admin access
#   Set ADMIN_EMAILS to your email to open /dashboard/admin/usage locally.
#
# =============================================================================
# Production (Vercel) — set in project env, not in .env
# =============================================================================
#
#   APP_URL=https://your-production-domain.com
#   NUXT_SESSION_PASSWORD → strong unique secret (never reuse dev value)
#   DATABASE_URL → production Neon branch
#   Stripe live keys (pk_live_ / sk_live_) + dashboard webhook → /api/stripe/webhook
#   Plaid production secret + PLAID_ENV=production + redirect + webhook URLs
#   UPSTASH_REDIS_* recommended on serverless
#
# Deploy checklist: README.md → Production (master branch)
# =============================================================================
