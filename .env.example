# =============================================================================
# FlowRate — environment variables
# =============================================================================
#
# Setup
#   cp .env.example .env
#   Fill in every variable in "Required" below, then: pnpm install && pnpm dev
#
# Docs: README.md (quick start)
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED — minimum to run the app locally
# -----------------------------------------------------------------------------

APP_URL=http://localhost:3000

# Signs session cookies. Min 32 chars. Generate: openssl rand -base64 32
# Alias supported: NEON_AUTH_COOKIE_SECRET
NUXT_SESSION_PASSWORD=change-me-use-openssl-rand-base64-32

# Neon → Project → Connection string (dev branch recommended per developer)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Neon Auth (account deletion, sign-in)
STACK_PROJECT_ID=your-neon-project-id
NUXT_NEON_AUTH_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth
NEON_API_KEY=your-neon-api-key
# Branch ID or endpoint ID from Neon console — must match the branch that hosts NUXT_NEON_AUTH_URL
NEON_BRANCH_ID=ep-xxx

# Stripe test keys — Dashboard → Developers → API keys (Test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# From `pnpm stripe:listen` (or `pnpm dev:all`). Restart dev after changing.
STRIPE_WEBHOOK_SECRET=whsec_...
# Dashboard → Settings → Invoice template
STRIPE_INVOICE_TEMPLATE_ID=inrtem_...

# Twilio — SMS OTP (account deletion + phone verify)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+14155551234

# Plaid — bank linking (sandbox)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=http://localhost:3000/api/plaid/webhook

# Admin dashboard (/dashboard/admin)
ADMIN_EMAILS=you@example.com

# In-app feedback → GitHub issues (fine-grained PAT: Issues + Contents; read@write)
GITHUB_TOKEN=github_pat_...
GITHUB_FEEDBACK_REPO=FlowrateOfficial/flowrate

# Address autocomplete — https://docs.mapbox.com/mapbox-search-js/guides/autofill/
MAPBOX_ACCESS_TOKEN=pk.eyJ...

# Rate limiting
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=


# -----------------------------------------------------------------------------
# OPTIONAL — Stripe billing extras
# -----------------------------------------------------------------------------

# Fallback Pro price if Products API lookup fails. Prefer Stripe product metadata planKey=pro
# STRIPE_PRICE_PRO=price_...

# Stripe products (create in Dashboard → Product catalog):
#   FlowRate Pro       → metadata planKey=pro
#   FlowRate Enterprise → metadata planKey=enterprise
# Add monthly + yearly prices per product in EUR, USD, and GBP (one Price per currency).
# Checkout picks the price that matches the user locale currency.
# Test cards: https://docs.stripe.com/testing


# -----------------------------------------------------------------------------
# OPTIONAL — Plaid extras
# -----------------------------------------------------------------------------

# OAuth banks only — must match URI at https://dashboard.plaid.com/team/api (HTTPS)
# PLAID_REDIRECT_URI=https://your-domain.com/dashboard/accounts/plaid-oauth


# -----------------------------------------------------------------------------
# OPTIONAL — Auth email (Neon send.otp / send.magic_link webhooks via Resend)
# -----------------------------------------------------------------------------

# Without these, configure Neon to use its built-in email or skip OTP webhooks in dev.
# RESEND_API_KEY=re_...
# AUTH_FROM_EMAIL=auth@your-domain.com

# Weekly digest cron (Vercel cron or external scheduler)
# CRON_SECRET=generate-a-long-random-string


# =============================================================================
# Local dev workflows
# =============================================================================
#
# Stripe webhooks
#   Terminal 1: pnpm dev
#   Terminal 2: pnpm stripe:listen
#   Paste the whsec_… into STRIPE_WEBHOOK_SECRET and restart dev
#   Without webhooks: checkout still syncs on redirect; bank sync webhooks return 503
#
# Neon Auth webhooks (OTP / magic link / phone verified)
#   Neon rejects localhost. Use ngrok (or similar) and register:
#     https://YOUR-SUBDOMAIN.ngrok-free.app/api/webhooks/neon-auth
#   Enable: send.otp, send.magic_link, phone_number.verified, user.created
#   Docs: https://neon.com/docs/auth/guides/webhooks
#
# Neon Auth allowed domains (fix INVALID_ORIGIN on preview deploys)
#   Console → Auth → Configuration → Domains:
#     http://localhost:3000
#     https://your-app.vercel.app
#     https://*.your-app.vercel.app
#
# Plaid on localhost
#   Sandbox works without PLAID_REDIRECT_URI on HTTP.
#   OAuth banks need HTTPS + registered redirect URI.
#
# =============================================================================
