# ══════════════════════════════════════════════════════════════════════════════
# FlowRate environment variables
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
# Local: http://localhost:3000
# Vercel: https://your-app.vercel.app (or your custom domain)
# On Vercel, VERCEL_URL is auto-set; set APP_URL explicitly if you use a custom domain.
APP_URL=http://localhost:3000

# Signs local auth session cookies (min 32 chars). Generate: openssl rand -base64 32
NUXT_SESSION_PASSWORD=your-32-char-minimum-secret-key-change-me-in-prod

# ── Neon Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Neon Auth (Better Auth) ───────────────────────────────────────────────────
# Console → Project → Branch → Auth → Configuration → Auth URL
NUXT_NEON_AUTH_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth

# Console → Auth → Providers → enable Google + GitHub
# Console → Auth → Configuration → Domains (required for production sign-up / OAuth):
#   https://your-app.vercel.app
#   https://your-custom-domain.com
#   https://*.your-app.vercel.app   (optional wildcard for preview deployments)
# Without these, sign-up returns INVALID_ORIGIN on Vercel.

STACK_PROJECT_ID=your-neon-project-id
NEON_API_KEY=your-neon-api-key
# Optional: Neon branch ID for guardian-initiated account deletion (auto-detected if omitted)
# NEON_BRANCH_ID=br-xxx

# ── Stripe ───────────────────────────────────────────────────────────────────
# TEST MODE (local dev) — only sandbox "Test Institution" banks, never real banks
# Dashboard → Developers → API keys → Test mode
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# LIVE MODE (real US banks) — requires ALL of the following:
#   1. Stripe account fully activated (identity + business verification)
#   2. Financial Connections application approved:
#      https://dashboard.stripe.com/financial-connections/application
#      Settings → Financial Connections → register use case "Data products"
#      Permissions needed: balances + transactions (already configured in app)
#   3. Deploy FlowRate on HTTPS (Vercel, etc.) — real banks do NOT work on http://localhost
#   4. Replace keys with live keys (pk_live_... / sk_live_...) in production env vars
#   5. APP_URL=https://your-production-domain.com
#   6. Live webhook endpoint (see below)
# Availability: businesses in the US, UK, EU, and other Stripe-supported regions may use
# Financial Connections. End users link US financial institutions only (filters.countries=US).
# Docs: https://docs.stripe.com/financial-connections
#       https://docs.stripe.com/financial-connections/fundamentals
#       https://docs.stripe.com/financial-connections/testing

# Local dev (required for webhooks to work):
#   1. Run `pnpm stripe:listen` in a second terminal
#   2. Copy the `whsec_…` signing secret from the CLI output
#   3. Paste it below and restart `pnpm dev`
# Without this, checkout still activates Pro via session sync on redirect — but
# bank balance/transaction webhooks will return 503 until the secret is set.
STRIPE_WEBHOOK_SECRET=whsec_...
#         URL: https://your-domain.com/api/stripe/webhook
#         Events (minimum):
#           checkout.session.completed
#           customer.subscription.created
#           customer.subscription.updated
#           customer.subscription.deleted
#           financial_connections.account.created
#           financial_connections.account.refreshed_balance
#           financial_connections.account.refreshed_transactions
#           financial_connections.account.deactivated
#           financial_connections.account.disconnected
STRIPE_WEBHOOK_SECRET=whsec_...

# Pro subscription price ID — optional fallback if Products API lookup fails
# Preferred: create a Product in Stripe Dashboard with metadata planKey=pro
STRIPE_PRICE_PRO=price_...

# Optional: expose test vs live in the UI (auto-detected from pk_live_ prefix)
# stripeLiveMode is derived from STRIPE_PUBLISHABLE_KEY — no extra env var needed

# ── Twilio (SMS notifications & phone verification) ───────────────────────────
# Console → Account → API keys & tokens
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
# Console → Verify → Services → create a service → copy Service SID (VA…)
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: outbound SMS alerts (not required for Verify OTP)
TWILIO_PHONE_NUMBER=+14155551234
