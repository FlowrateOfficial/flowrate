// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum SpaceType {
  INDEPENDENT
  HOUSEHOLD
  FAMILY
  COMPANY
}

enum SpaceRole {
  OWNER
  CO_GUARDIAN
  TEEN
  CHILD
  FINANCE_ADMIN
  MANAGER
  MEMBER
  GUEST
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
  CRYPTO
  CLOUD
}

enum AccountVisibility {
  PERSONAL
  SHARED
}

enum TransactionCategory {
  HOUSING
  FOOD
  TRANSPORT
  SUBSCRIPTIONS
  UTILITIES
  HEALTHCARE
  ENTERTAINMENT
  EDUCATION
  SHOPPING
  SAVINGS
  INCOME
  CLOUD_INFRA
  DEVELOPER_TOOLS
  OTHER
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAUSED
  PRICE_CHANGED
}

enum SplitRuleType {
  EQUAL
  PROPORTIONAL
  CUSTOM
}

/// Stripe Billing subscription lifecycle (mirrors Stripe API statuses).
enum BillingSubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// User profile — ID is sourced from Neon Auth.
model User {
  id               String   @id
  email            String   @unique
  name             String?
  phone            String?  @unique
  phoneVerifiedAt  DateTime?
  avatarUrl        String?
  plan             Plan     @default(FREE)
  activeSpaceId    String?
  dateOfBirth      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  activeSpace      FinancialSpace? @relation("ActiveSpace", fields: [activeSpaceId], references: [id], onDelete: SetNull)
  ownedSpaces      FinancialSpace[] @relation("SpaceOwner")
  memberships      SpaceMember[]
  accounts         Account[]
  transactions     Transaction[]
  budgets          Budget[]
  subscriptions    DetectedSubscription[]
  billing          UserBilling?

  @@map("users")
}

/// Stripe Billing customer profile — one per user (`cus_…`).
model UserBilling {
  userId           String   @id
  stripeCustomerId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription BillingSubscription?

  @@map("user_billing")
}

/// Stripe subscription record synced from webhooks / checkout (`sub_…`).
model BillingSubscription {
  id                   String                    @id @default(cuid())
  userId               String                    @unique
  stripeSubscriptionId String                    @unique
  stripePriceId        String
  stripeProductId      String?
  status               BillingSubscriptionStatus
  planKey              String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean                   @default(false)
  canceledAt           DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  billing UserBilling @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([status])
  @@map("billing_subscriptions")
}

/// A financial space: Independent, Household, Family, or Company.
model FinancialSpace {
  id        String    @id @default(cuid())
  name      String
  type      SpaceType
  ownerId   String
  settings  Json      @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  owner           User                   @relation("SpaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  activeForUsers  User[]                 @relation("ActiveSpace")
  members         SpaceMember[]
  invitations     SpaceInvitation[]
  accounts        Account[]
  transactions    Transaction[]
  budgets         Budget[]
  subscriptions   DetectedSubscription[]
  childProfiles   ChildProfile[]
  splitRules      SplitRule[]

  @@index([ownerId])
  @@map("financial_spaces")
}

/// Membership linking a user (or pending invite) to a space with a role.
model SpaceMember {
  id          String       @id @default(cuid())
  spaceId     String
  userId      String?
  email       String?
  phone       String?
  role        SpaceRole
  status      MemberStatus @default(PENDING)
  displayName String?
  dateOfBirth DateTime?
  invitedBy   String?
  joinedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  space       FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  childProfile ChildProfile?

  @@unique([spaceId, userId])
  @@unique([spaceId, email])
  @@index([userId])
  @@index([spaceId])
  @@map("space_members")
}

model SpaceInvitation {
  id              String    @id @default(cuid())
  spaceId         String
  email           String?
  phone           String?
  displayName     String?
  role            SpaceRole
  token           String    @unique @default(cuid())
  expiresAt       DateTime
  phoneVerifiedAt DateTime?
  createdAt       DateTime  @default(now())

  space FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@index([token])
  @@index([phone])
  @@map("space_invitations")
}

/// Child/teen profile with allowance and supervision settings.
model ChildProfile {
  id                 String        @id @default(cuid())
  spaceId            String
  memberId           String        @unique
  allowanceAmount    Decimal?      @db.Decimal(12, 2)
  allowanceFrequency BudgetPeriod?
  spendingLimits     Json          @default("{}")
  learnMode          Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  space  FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  member SpaceMember    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  jars   AllowanceJar[]

  @@index([spaceId])
  @@map("child_profiles")
}

model AllowanceJar {
  id             String   @id @default(cuid())
  childProfileId String
  name           String
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  targetAmount   Decimal? @db.Decimal(12, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  childProfile ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)

  @@index([childProfileId])
  @@map("allowance_jars")
}

/// How expenses are split between space members.
model SplitRule {
  id       String               @id @default(cuid())
  spaceId  String
  name     String
  category TransactionCategory?
  ruleType SplitRuleType        @default(EQUAL)
  splits   Json                 @default("{}")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  space FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@map("split_rules")
}

model Account {
  id                    String            @id @default(cuid())
  userId                String
  spaceId               String
  name                  String
  institution           String?
  type                  AccountType
  visibility            AccountVisibility @default(PERSONAL)
  balance               Decimal           @db.Decimal(12, 2)
  currency              String            @default("USD")
  /// Stripe Financial Connections account ID (`fca_…`).
  stripeFcAccountId     String?           @unique @map("stripeFinancialConnId")
  lastSynced            DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  space        FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([spaceId])
  @@map("accounts")
}

model Transaction {
  id          String              @id @default(cuid())
  userId      String
  spaceId     String
  accountId   String
  amount      Decimal             @db.Decimal(12, 2)
  currency    String              @default("USD")
  description String
  merchant    String?
  category    TransactionCategory @default(OTHER)
  date        DateTime
  pending     Boolean             @default(false)
  /// Stripe Financial Connections transaction ID (`fctxn_…`).
  stripeTransactionId String?       @unique @map("stripeId")
  createdAt   DateTime            @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  space   FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  account Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([spaceId])
  @@index([spaceId, date])
  @@index([accountId])
  @@index([date])
  @@map("transactions")
}

model Budget {
  id        String              @id @default(cuid())
  userId    String
  spaceId   String
  name      String
  category  TransactionCategory
  amount    Decimal             @db.Decimal(12, 2)
  period    BudgetPeriod
  isShared  Boolean             @default(false)
  startDate DateTime
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  space FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([spaceId])
  @@map("budgets")
}

model DetectedSubscription {
  id          String              @id @default(cuid())
  userId      String
  spaceId     String
  name        String
  amount      Decimal             @db.Decimal(12, 2)
  currency    String              @default("USD")
  frequency   BudgetPeriod
  category    TransactionCategory @default(SUBSCRIPTIONS)
  status      SubscriptionStatus  @default(ACTIVE)
  icon        String?
  lastCharged DateTime?
  nextCharge  DateTime?
  priceAlert  Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  space FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([spaceId])
  @@map("detected_subscriptions")
}
