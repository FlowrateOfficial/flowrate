// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum SpaceType {
  INDEPENDENT
  HOUSEHOLD
  FAMILY
  COMPANY
}

enum SpaceRole {
  OWNER
  CO_GUARDIAN
  TEEN
  CHILD
  FINANCE_ADMIN
  MANAGER
  MEMBER
  GUEST
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
  CRYPTO
  CLOUD
}

enum AccountVisibility {
  PERSONAL
  SHARED
}

enum TransactionCategory {
  HOUSING
  FOOD
  TRANSPORT
  SUBSCRIPTIONS
  UTILITIES
  HEALTHCARE
  ENTERTAINMENT
  EDUCATION
  SHOPPING
  SAVINGS
  INCOME
  CLOUD_INFRA
  DEVELOPER_TOOLS
  OTHER
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAUSED
  PRICE_CHANGED
}

enum SplitRuleType {
  EQUAL
  PROPORTIONAL
  CUSTOM
}

/// Stripe Billing subscription lifecycle (mirrors Stripe API statuses).
enum SubStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

/// Bank link source: Stripe (US) or Plaid (EU).
enum LinkProvider {
  STRIPE
  PLAID
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// User profile — ID is sourced from Neon Auth.
model User {
  id            String    @id
  email         String    @unique
  name          String?
  phone         String?   @unique
  phoneVerified DateTime?
  avatar        String?
  plan          Plan      @default(FREE)
  spaceId       String?
  birthday      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  space        FinancialSpace? @relation("ActiveSpace", fields: [spaceId], references: [id], onDelete: SetNull)
  ownedSpaces  FinancialSpace[] @relation("SpaceOwner")
  memberships  SpaceMember[]
  accounts     Account[]
  transactions Transaction[]
  budgets      Budget[]
  subscriptions DetectedSubscription[]
  billing      UserBilling?
  plaidLinks   PlaidLink[]
  usage        UserUsage?
  feedback     FeedbackSubmission[]

  @@map("users")
}

/// One Plaid bank login (item) — stores access token for EU sync.
model PlaidLink {
  id          String            @id @default(cuid())
  userId      String
  spaceId     String
  ref         String            @unique
  token       String
  institution String?
  visibility  AccountVisibility @default(PERSONAL)
  syncCursor  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([spaceId])
  @@map("plaid_links")
}

/// Stripe Billing customer profile — one per user (`cus_…`).
model UserBilling {
  userId     String   @id
  customerId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription BillingSubscription?

  @@map("user_billing")
}

/// Stripe subscription record synced from webhooks / checkout (`sub_…`).
model BillingSubscription {
  id          String    @id @default(cuid())
  userId      String    @unique
  subId       String    @unique
  priceId     String
  productId   String?
  status      SubStatus
  planKey     String?
  periodStart DateTime?
  periodEnd   DateTime?
  cancelAtEnd Boolean   @default(false)
  canceledAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  billing UserBilling @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([status])
  @@map("billing_subscriptions")
}

/// Per-user usage counters for plan enforcement and admin reporting.
model UserUsage {
  userId         String    @id
  syncCountMonth Int       @default(0)
  syncMonthKey   String    @default("")
  lastSyncAt     DateTime?
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_usage")
}

/// A financial space: Independent, Household, Family, or Company.
model FinancialSpace {
  id        String    @id @default(cuid())
  name      String
  type      SpaceType
  ownerId   String
  settings  Json      @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  owner          User                   @relation("SpaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  activeForUsers User[]                 @relation("ActiveSpace")
  members        SpaceMember[]
  invitations    SpaceInvitation[]
  accounts       Account[]
  transactions   Transaction[]
  budgets        Budget[]
  subscriptions  DetectedSubscription[]
  childProfiles  ChildProfile[]
  splitRules     SplitRule[]

  @@index([ownerId])
  @@map("financial_spaces")
}

/// Membership linking a user (or pending invite) to a space with a role.
model SpaceMember {
  id        String       @id @default(cuid())
  spaceId   String
  userId    String?
  email     String?
  phone     String?
  role      SpaceRole
  status    MemberStatus @default(PENDING)
  name      String?
  birthday  DateTime?
  invitedBy String?
  joinedAt  DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  space        FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  childProfile ChildProfile?

  @@unique([spaceId, userId])
  @@unique([spaceId, email])
  @@index([userId])
  @@index([spaceId])
  @@map("space_members")
}

model SpaceInvitation {
  id            String    @id @default(cuid())
  spaceId       String
  email         String?
  phone         String?
  name          String?
  role          SpaceRole
  token         String    @unique @default(cuid())
  expiresAt     DateTime
  phoneVerified DateTime?
  createdAt     DateTime  @default(now())

  space FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@index([token])
  @@index([phone])
  @@map("space_invitations")
}

/// Child/teen profile with allowance and supervision settings.
model ChildProfile {
  id        String        @id @default(cuid())
  spaceId   String
  memberId  String        @unique
  allowance Decimal?      @db.Decimal(12, 2)
  frequency BudgetPeriod?
  limits    Json          @default("{}")
  learnMode Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  space  FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  member SpaceMember    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  jars   AllowanceJar[]

  @@index([spaceId])
  @@map("child_profiles")
}

model AllowanceJar {
  id        String   @id @default(cuid())
  childId   String
  name      String
  balance   Decimal  @default(0) @db.Decimal(12, 2)
  target    Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  child ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@map("allowance_jars")
}

/// How expenses are split between space members.
model SplitRule {
  id        String               @id @default(cuid())
  spaceId   String
  name      String
  category  TransactionCategory?
  mode      SplitRuleType        @default(EQUAL)
  splits    Json                 @default("{}")
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  space FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@map("split_rules")
}

model Account {
  id          String            @id @default(cuid())
  userId      String
  spaceId     String
  name        String
  institution String?
  type        AccountType
  visibility  AccountVisibility @default(PERSONAL)
  balance     Decimal           @db.Decimal(12, 2)
  currency    String            @default("USD")
  provider    LinkProvider      @default(STRIPE)
  stripeId    String?           @unique
  plaidId     String?           @unique
  linkId      String?
  syncedAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  space        FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([spaceId])
  @@map("accounts")
}

model Transaction {
  id          String              @id @default(cuid())
  userId      String
  spaceId     String
  accountId   String
  amount      Decimal             @db.Decimal(12, 2)
  currency    String              @default("USD")
  description String
  merchant    String?
  category    TransactionCategory @default(OTHER)
  date        DateTime
  pending     Boolean             @default(false)
  stripeId    String?             @unique
  plaidId     String?             @unique
  createdAt   DateTime            @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  space   FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  account Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([spaceId])
  @@index([spaceId, date])
  @@index([accountId])
  @@index([date])
  @@map("transactions")
}

model Budget {
  id        String              @id @default(cuid())
  userId    String
  spaceId   String
  name      String
  category  TransactionCategory
  amount    Decimal             @db.Decimal(12, 2)
  period    BudgetPeriod
  isShared  Boolean             @default(false)
  startDate DateTime
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  space FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([spaceId])
  @@map("budgets")
}

model DetectedSubscription {
  id         String              @id @default(cuid())
  userId     String
  spaceId    String
  name       String
  amount     Decimal             @db.Decimal(12, 2)
  currency   String              @default("USD")
  frequency  BudgetPeriod
  category   TransactionCategory @default(SUBSCRIPTIONS)
  status     SubscriptionStatus  @default(ACTIVE)
  icon       String?
  lastCharge DateTime?
  nextCharge DateTime?
  alert      Boolean             @default(false)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  space FinancialSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([spaceId])
  @@map("detected_subscriptions")
}

/// In-app feedback linked to a private GitHub issue.
model FeedbackSubmission {
  id          String   @id @default(cuid())
  userId      String
  issueNumber Int
  type        String
  title       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, issueNumber])
  @@index([userId, createdAt])
  @@map("feedback_submissions")
}
